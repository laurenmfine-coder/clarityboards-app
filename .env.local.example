# Supabase — get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# These are the same values — Supabase auth helpers need both forms
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Anthropic — for AI parsing
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# Twilio — for SMS/MMS
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE

# Postmark — for email parsing
POSTMARK_WEBHOOK_TOKEN=YOUR_POSTMARK_TOKEN_HERE
